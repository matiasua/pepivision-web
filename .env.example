# Copy this file to .env and fill in real values for your machine.
# .env is gitignored — never commit real secrets.

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:8080
SESSION_SECRET=changeme-generate-a-long-random-string

# Base URL used to build ABSOLUTE asset URLs (logo, etc.) inside
# transactional emails — email clients never load app-relative paths, and
# never resolve internal Docker hostnames. Optional: falls back to APP_URL
# when unset. In development this can just repeat APP_URL; in production
# set it to the real public domain once one exists.
EMAIL_ASSET_BASE_URL=http://localhost:8080

# --- PostgreSQL (service: postgres) ---
# POSTGRES_USER/DATABASE_URL is the Postgres bootstrap SUPERUSER — used only
# by the `migrate` service (DDL) and by `db-init` to provision the
# restricted app role below. The running app (`web`) never connects as
# this user; see design.md -> "Controles de seguridad" (Fase 8, principio
# de mínimo privilegio).
POSTGRES_DB=pepivision360
POSTGRES_USER=pepivision360
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pepivision360:changeme@postgres:5432/pepivision360

# Least-privilege application role (SELECT/INSERT/UPDATE/DELETE only — no
# DDL, no superuser) that `web` actually connects as at runtime. Provisioned
# idempotently by the one-shot `db-init` service; see db/init-app-role.sql.
APP_DB_USER=pepivision360_app
APP_DB_PASSWORD=changeme-app
DATABASE_URL_APP=postgresql://pepivision360_app:changeme-app@postgres:5432/pepivision360

# --- Object storage abstraction (service: minio in development) ---
OBJECT_STORAGE_ENDPOINT=http://minio:9000
# Browser-facing base URL for the same bucket (the app's own container
# reaches MinIO via the internal Docker network above; a browser on the
# host cannot resolve "minio", so served image URLs use this instead).
OBJECT_STORAGE_PUBLIC_URL=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=pepivision360-products
OBJECT_STORAGE_ACCESS_KEY=changeme
OBJECT_STORAGE_SECRET_KEY=changeme-secret
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Separate, non-public bucket for sensitive request attachments
# (prescriptions) — no anonymous read access, no *_PUBLIC_URL counterpart.
# Reachable only via short-lived signed URLs generated after an
# authenticated admin request; see modules/storage/private-service.ts.
PRIVATE_OBJECT_STORAGE_BUCKET=pepivision360-attachments

# MinIO container's own admin credentials (in development these can match
# OBJECT_STORAGE_ACCESS_KEY/SECRET_KEY for simplicity; see design.md).
MINIO_ROOT_USER=changeme
MINIO_ROOT_PASSWORD=changeme-secret

# --- SMTP abstraction (service: mailpit in development, no real auth) ---
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@pepivision360.local
# Mailpit has no TLS at all — keep both false here. A real production SMTP
# provider must set at least one of these (SMTP_SECURE=true for port 465,
# or SMTP_REQUIRE_TLS=true for STARTTLS on port 587); see
# modules/notifications/client.ts and modules/notifications/README.md.
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false

# Optional DKIM signing for outgoing mail — all three must be set together
# to activate (see modules/notifications/client.ts). Left blank in
# development: Mailpit doesn't validate signatures and there's no real
# sending domain yet. Required for production deliverability alongside an
# SPF TXT record and a DMARC policy for the sending domain — none of
# which this app can provision itself (DNS-level, outside Docker Compose);
# see modules/notifications/README.md.
DKIM_DOMAIN_NAME=
DKIM_KEY_SELECTOR=
DKIM_PRIVATE_KEY=

# --- Adminer (optional, profile "tools") ---
ADMINER_PORT=8081

# --- Superadmin provisioning (only read by `npm run admin:create-superadmin`,
# not by the app itself — safe to leave unset day to day; pass them inline
# on the command instead of committing real values here). ---
SUPERADMIN_EMAIL=
SUPERADMIN_USERNAME=
SUPERADMIN_NAME=
SUPERADMIN_PASSWORD=
